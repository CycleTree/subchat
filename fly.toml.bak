# OpenClaw on Fly.io Configuration  
app = "subchat-openclaw-gateway"
primary_region = "nrt"

[env]
  PORT = "8080"
  OPENCLAW_GATEWAY_PORT = "8080"
  OPENCLAW_GATEWAY_TOKEN = "subchat-gateway-token-2026"
  NODE_ENV = "production"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  min_machines_running = 1

[http_service.concurrency]
  type = "connections"
  hard_limit = 25
  soft_limit = 20

[[mounts]]
  destination = "/data"
  source = "openclaw_data"
