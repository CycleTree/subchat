{
  "name": "subchat",
  "version": "2.1.0",
  "description": "OpenClaw SubAgent Conversation Visibility Tool",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=@subchat/ui",
    "build": "npm run build:shared && npm run build:ui",
    "build:shared": "npm run build --workspace=@subchat/shared",
    "build:ui": "npm run build --workspace=@subchat/ui",
    "preview": "npm run preview --workspace=@subchat/ui",
    "test": "npm run test --workspace=@subchat/ui",
    "lint": "npm run lint --workspaces",
    "deploy:pages": "npm run build && gh-pages -d packages/ui/dist",
    "fly:deploy": "fly deploy",
    "fly:logs": "fly logs",
    "fly:status": "fly status"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "gh-pages": "^6.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CycleTree/subchat"
  },
  "author": "CycleTree",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "subagent",
    "conversation",
    "visibility",
    "ui"
  ],
  "dependencies": {
    "ws": "^8.19.0"
  }
}
